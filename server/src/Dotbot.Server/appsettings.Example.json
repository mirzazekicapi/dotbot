{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "../../logs/dotbot-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "MicrosoftAppTenantId": "<tenant id>",
  "MicrosoftAppId": "<from terraform output azuread_app_id>",
  "MicrosoftAppPassword": "<from terraform output azuread_app_password>",
  "TokenValidation": {
    "Enabled": true,
    "Audiences": [ "<MicrosoftAppId>" ],
    "TenantId": "<MicrosoftAppTenantId>"
  },
  "Connections": {
    "ServiceConnection": {
      "Assembly": "Microsoft.Agents.Authentication.Msal",
      "Type": "MsalAuth",
      "Settings": {
        "AuthType": "ClientSecret",
        "AuthorityEndpoint": "https://login.microsoftonline.com/<MicrosoftAppTenantId>",
        "ClientId": "<MicrosoftAppId>",
        "ClientSecret": "<MicrosoftAppPassword>",
        "Scopes": [ "https://api.botframework.com/.default" ]
      }
    }
  },
  "BlobStorage": {
    "AccountUri": "https://REPLACE-WITH-STORAGE-ACCOUNT.blob.core.windows.net",
    "ConnectionString": ""
  },
  "ApiSecurity": {
    "ApiKey": "<shared secret sent in X-Api-Key header by dotbot clients>"
  },
  "Auth": {
    "JwtSigningKey": "dev-only-signing-key-do-not-use-in-production-32chars!",
    "MagicLinkExpiryMinutes": 60,
    "SeedAdministrators": [ "your.email@example.com" ]
  },
  "DeliveryChannels": {
    "Email": {
      "Enabled": false,
      "SenderAddress": "dotbot@example.com",
      "SenderDisplayName": "Dotbot"
    },
    "Jira": {
      "Enabled": false,
      "BaseUrl": "https://<tenant>.atlassian.net",
      "Username": "dotbot@example.com",
      "ApiToken": ""
    },
    "Slack": {
      "Enabled": false,
      "BotToken": "xoxb-..."
    }
  },
  "Reminders": {
    "DefaultReminderAfterHours": 24,
    "DefaultEscalateAfterDays": 3,
    "IntervalMinutes": 60
  },
  "BusinessHours": {
    "Enabled": true,
    "StartHour": 8,
    "EndHour": 18,
    "ExemptChannels": [ "jira", "slack" ],
    "FallbackTimeZone": "UTC",
    "FallbackCountryCode": "GB"
  },
  "Validation": {
    "QuestionTemplate": {
      "MaxAttachments": 20,
      "MaxReferenceLinks": 20
    }
  }
}
