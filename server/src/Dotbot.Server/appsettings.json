{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Agents": "Information",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "Properties": {
      "Application": "Dotbot.Server"
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "AllowedHosts": "*",
  "TokenValidation": {
    "Enabled": true,
    "Audiences": [
      "{{MicrosoftAppId}}"
    ],
    "TenantId": "{{MicrosoftAppTenantId}}"
  },
  "Connections": {
    "ServiceConnection": {
      "Assembly": "Microsoft.Agents.Authentication.Msal",
      "Type": "MsalAuth",
      "Settings": {
        "AuthType": "ClientSecret",
        "AuthorityEndpoint": "https://login.microsoftonline.com/{{MicrosoftAppTenantId}}",
        "ClientId": "{{MicrosoftAppId}}",
        "ClientSecret": "{{MicrosoftAppPassword}}",
        "Scopes": [
          "https://api.botframework.com/.default"
        ]
      }
    }
  },
  "Auth": {
    "KeyVaultUri": "",
    "KeyName": "dotbot-jwt-signing",
    "JwtSigningKey": "",
    "JwtIssuer": "dotbot",
    "JwtAudience": "dotbot-respond",
    "MagicLinkExpiryMinutes": 15,
    "DeviceTokenExpiryDays": 90,
    "CookieName": "dotbot_device",
    "SeedAdministrators": []
  },
  "DeliveryChannels": {
    "Email": {
      "Enabled": false,
      "SenderAddress": "",
      "SenderDisplayName": "Dotbot"
    },
    "Jira": {
      "Enabled": false,
      "BaseUrl": "",
      "Username": "",
      "ApiToken": ""
    }
  },
  "Reminders": {
    "DefaultReminderAfterHours": 24,
    "DefaultEscalateAfterDays": 3,
    "IntervalMinutes": 60
  },
  "BusinessHours": {
    "Enabled": true,
    "StartHour": 8,
    "EndHour": 18,
    "ExemptChannels": ["jira", "slack"],
    "FallbackTimeZone": "UTC",
    "FallbackCountryCode": "GB"
  }
}
